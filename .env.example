# Postgres (Neon/Supabase connection string — must be publicly reachable so the
# GitHub Actions cron can connect). Never commit the real .env.
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# YouTube Data API v3 key (Google Cloud console > Credentials > API key)
YOUTUBE_API_KEY=your_key_here

# OpenAI key — used only to tag video attributes (hook/topic/angle), not ranking
OPENAI_API_KEY=your_key_here

# Comma-separated channel handles to track (the roster)
TRACKED_CHANNELS=@nicksaraev,@LiamOttley
